# ==========================================
# 1. VARIAVEIS DA API ISHIKAWA
# ==========================================
# A API Ishikawa (FastAPI) acessa o Router (FastAPI) localmente na porta 8001
ROUTER_BASE_URL=http://localhost:8001
ROUTER_SECRET_KEY="Api-key"
ML_API_KEY="Api-key"
ML_API_URL = https://api-educampoml-custoleite-4j44.onrender.com
API_KEY="Api-key"
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL="100/minute"
RATE_LIMIT_DIAGNOSTICO="10/minute"
RATE_LIMIT_SIMULACAO="20/minute"
RATE_LIMIT_PARAMETROS="60/minute"
RATE_LIMIT_TEST_DATA="10/minute"

# ==========================================
# 2. VARIAVEIS DO LLM ROUTER
# ==========================================
OPENROUTER_API_KEY="cole_sua_chave_do_openrouter_aqui"

# Modelos pagos
ISHIKAWA_MODELS=["google/gemini-3.1-flash-lite"]
SEVERIDADE_MODELS=["openai/gpt-oss-20b", "openai/gpt-5-nano", "deepseek/deepseek-v4-flash", "google/gemini-2.5-flash-lite", "qwen/qwen3.6-flash", "anthropic/claude-3-haiku", "openai/gpt-5-mini"]

GLOBAL_CONCURRENT_MARGIN="2"
MODEL_RPM_BURST_THRESHOLD="6"
SEVERIDADE_OPENROUTER_PRESET="@preset/llm-router-severidade"
ISHIKAWA_OPENROUTER_PRESET="@preset/llm-router-diagnostico"
ALLOWED_DOMAINS=["http://localhost:8000"]

APP_NAME="API_LLM_Router"
APP_URL="https://github.com/Educampo-UFV/API_LLM_Router.git"

# ==========================================
# 3. VARIAVEIS DO SITE NEXT.JS (FRONTEND)
# ==========================================
# O BFF (Next.js server) se comunica com a API Ishikawa na porta 8000
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=/api

# Token de Autenticacao da API
API_TOKEN="Api-key"

ENABLE_PAYLOAD_ENCRYPTION=false
ENCRYPTION_SECRET_KEY="Api-key"

# Credenciais de Admin
ADMIN_USERNAME=admin_local
ADMIN_PASSWORD=senha_local_123

NEXT_PUBLIC_ENABLE_TEST_FARMS=true
